# Soma v2 talks to Supabase over HTTPS (PostgREST) instead of a local
# SQLite file, so it can run on Vercel or any environment where a raw
# Postgres TCP connection is not available.
#
# 1. Create a Supabase project.
# 2. Run supabase/schema.sql in the Supabase SQL Editor.
# 3. Copy this file to `.env.local` and fill in the values below
#    (Project Settings > API in the Supabase dashboard).

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# service_role secret key (NOT the anon/public key).
# This key bypasses Row Level Security, so keep it server-side only —
# never expose it to the browser or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=
